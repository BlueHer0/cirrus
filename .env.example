# Django
SECRET_KEY=cambiar-esto-a-algo-seguro
DEBUG=True
ALLOWED_HOSTS=cirrus.nubex.me,localhost,127.0.0.1

# Base de datos (Host-First — PostgreSQL local en VPS2)
DATABASE_URL=postgresql://cirrus:password@localhost:5432/cirrus_db

# Redis (Host-First — Redis local en VPS2)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# MinIO (S3-compatible en VPSx)
MINIO_ENDPOINT=https://vpsx.tudominio.com:9000
MINIO_ACCESS_KEY=tu-access-key
MINIO_SECRET_KEY=tu-secret-key
MINIO_BUCKET=cirrus
MINIO_USE_SSL=true

# Fernet key para encriptar passwords de FIEL
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIEL_ENCRYPTION_KEY=generar-con-Fernet.generate_key()

# Playwright
PLAYWRIGHT_BROWSERS_PATH=/var/www/cirrus/.browsers
